#!/usr/bin/env bash
set -e

export UV_CACHE_DIR=/root/capsule/scratch/.cache
mkdir -p "${UV_CACHE_DIR}"

# Check if the --update-copilot flag is present and set a variable accordingly
update_copilot=false
copilot_args=()
for arg in "$@"; do
  if [[ "${arg}" == "--update-copilot" || "${arg}" == --update-copilot=* ]]; then
    update_copilot=true
  else
    copilot_args+=("${arg}")
  fi
done

if [[ "${update_copilot}" == true ]]; then
  (set -ex; copilot update)
  else
    (set -ex; copilot version)
fi

# keep copies of copilot's config & logs - they're interesting
cp -r /root/capsule/code/.agents /root/capsule/results/.copilot
cp -r /root/capsule/code/.copilot /root/capsule/results
cp /root/capsule/code/AGENTS.md /root/capsule/results/AGENTS.md
export COPILOT_HOME="/root/capsule/results/.copilot"

# ------------- set agent workspace dir --------------------
# agents are reluctant to write outside of their cwd
AGENT_DIR="${AGENT_DIR:-/root/capsule}"
# ----------------------------------------------------------
cp /root/capsule/code/AGENTS.md "$AGENT_DIR/AGENTS.md"
set -x
cd "$AGENT_DIR"
copilot "${copilot_args[@]}" --autopilot --yolo --share=/root/capsule/results/copilot-session.md