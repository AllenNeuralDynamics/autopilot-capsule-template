#!/usr/bin/env bash
set -euo pipefail

export UV_CACHE_DIR=/root/capsule/scratch/.cache
export PATH="/root/.local/bin:${HOME:-/root}/.local/bin:$PATH"
mkdir -p "${UV_CACHE_DIR}"

prompt=""
model=""
effort=""
use_bedrock=false
claude_args=()

is_truthy() {
  [[ "${1}" =~ ^(1|true|yes|on)$ ]]
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --update-claude)
      if [[ $# -gt 1 && "$2" != --* ]]; then
        update_value="$2"
      else
        update_value="1"
      fi
      if is_truthy "${update_value}"; then
        claude update
      fi
      if [[ $# -gt 1 && "$2" != --* ]]; then
        shift 2
      else
        shift
      fi
      continue
      ;;
    --update-claude=*)
      is_truthy "${1#*=}" && claude update
      ;;
    --use-bedrock)
      if [[ $# -gt 1 && "$2" != --* ]]; then
        bedrock_value="$2"
      else
        bedrock_value="1"
      fi
      is_truthy "${bedrock_value}" && use_bedrock=true
      if [[ $# -gt 1 && "$2" != --* ]]; then
        shift 2
      else
        shift
      fi
      continue
      ;;
    --use-bedrock=*)
      is_truthy "${1#*=}" && use_bedrock=true
      ;;
    --model)
      if [[ $# -gt 1 && "$2" != --* ]]; then
        model="$2"
        shift 2
      else
        shift
      fi
      continue
      ;;
    --model=*)
      model="${1#*=}"
      ;;
    --effort)
      if [[ $# -gt 1 && "$2" != --* ]]; then
        effort="$2"
        shift 2
      else
        shift
      fi
      continue
      ;;
    --effort=*)
      effort="${1#*=}"
      ;;
    --prompt)
      if [[ $# -lt 2 ]]; then
        echo "--prompt requires a value" >&2
        exit 2
      fi
      prompt="$2"
      shift 2
      continue
      ;;
    --prompt=*)
      prompt="${1#*=}"
      ;;
    *)
      claude_args+=("$1")
      ;;
  esac
  shift
done

if [[ -n "${model}" ]]; then
  claude_args+=(--model "${model}")
fi

if [[ -n "${effort}" ]]; then
  claude_args+=(--effort "${effort}")
fi

(set -ex; claude --version)

if [[ -z "${prompt}" ]]; then
  echo "No prompt supplied. Pass --prompt '...'" >&2
  exit 2
fi

# ------------- set agent workspace dir --------------------
# agents are reluctant to write outside of their cwd
AGENT_DIR="${AGENT_DIR:-/root/capsule}"
# ----------------------------------------------------------
mkdir -p "$AGENT_DIR"
mkdir -p /root/capsule/results

# keep copies of Claude Code's config, skills, and run logs
export CLAUDE_CONFIG_DIR="/root/capsule/results/.claude"
mkdir -p "$CLAUDE_CONFIG_DIR"
cp -R /root/capsule/code/.agents/. "$CLAUDE_CONFIG_DIR/"
cp /root/capsule/code/CLAUDE.md /root/capsule/results/CLAUDE.md

if [[ "${use_bedrock}" == true ]]; then
  export CLAUDE_CODE_USE_BEDROCK=1
fi

cp /root/capsule/code/CLAUDE.md "$AGENT_DIR/CLAUDE.md"

cd "$AGENT_DIR"
IS_SANDBOX=1 claude \
  --print \
  --debug-file /root/capsule/results/.claude/claude-code-debug.log \
  --include-hook-events \
  "${claude_args[@]}" \
  -p "${prompt}" \
  </dev/null \
  2>&1 | tee /root/capsule/results/claude-code-session.log
